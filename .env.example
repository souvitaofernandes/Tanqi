# Supabase project URL — found in Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key — found in Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# (Optional) Override the email-confirmation redirect URL used during sign-up.
# Needed in local development where Supabase cannot reach localhost automatically.
# In production this defaults to window.location.origin/auth/callback — leave unset.
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback
